{
  "manifest_version": 3,
  "name": "Cookie Trax",
  "version": "1.0",
  "description": "Activity tracking app - Analyze privacy policies & cookies for risky data practices.",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["detect-cookies.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["analyzer.js", "analyzer-worker.js", "storage.js", "ui-renderer.js", "insights-generator.js", "cookie-analyzer.js"],
      "matches": ["<all_urls>"]
    }
  ]
}